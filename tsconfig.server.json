{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "rootDir": "src",
    "outDir": "dist/api",
    "noEmit": false,
    "isolatedModules": false
  },
  "include": ["src/server/**/*.ts", "src/shared/**/*.ts"]
}
