{
  "name": "npl-bidding-system",
  "version": "1.0.0",
  "description": "IIIT Nagpur Premier League web-based player auction and bidding platform.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"tsx watch src/server/index.ts\" \"vite --host 127.0.0.1\"",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/api/server/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
